KR_PORT=8787
KR_HOST=0.0.0.0
KR_SERVICE_VERSION=0.0.1

# -----------------------------------------------------------------------------
# Postgres persistence (R8 / Phase 13). Omit to use FileStore (KR_STORE_DIR/store.json).
# -----------------------------------------------------------------------------
# KR_DATABASE_URL=postgres://kindrail:secret@localhost:5432/kindrail

# Web Push (optional). Generate keys: npx web-push generate-vapid-keys
# KR_VAPID_PUBLIC_KEY=
# KR_VAPID_PRIVATE_KEY=
# KR_PUSH_SUBJECT=mailto:ops@example.com

# Daily push cron (optional). curl/GitHub Actions calls POST /internal/push/daily with header x-kr-internal-cron-secret
# KR_INTERNAL_CRON_SECRET=

# Google Sign-In (GIS): Web Client ID — gateway verifies JWT audience (optional).
# KR_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# Companion web build (same Client ID):
# VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# IAP — Premium Battle Pass verify (POST /iap/battle-pass/verify, gateway R7)
# -----------------------------------------------------------------------------
# Apple: App Store Connect shared secret for legacy verifyReceipt (prod first, 21007 → sandbox).
# KR_APPLE_IAP_SHARED_SECRET=
#
# Google Play: applicationId + service account JSON (Play Developer API: purchases.products.get).
# KR_GOOGLE_PLAY_PACKAGE_NAME=com.example.kindrail
# KR_GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH=/path/to/play-developer-sa.json
#
# Store product IDs must match client SKU; gateway rejects other productId values.
# KR_IAP_BATTLE_PASS_PRODUCT_ID_IOS=kindrail_bp_premium_s0_ios
# KR_IAP_BATTLE_PASS_PRODUCT_ID_ANDROID=kindrail_bp_premium_s0_android
#
# Dev-only: if true and receipt body is exactly STUB_PREMIUM, premium is granted when SKU matches.
# Leave false or unset in production.
# KR_IAP_ALLOW_STUB=false
#
# Companion-web dev QA panel (optional overrides; defaults match SKU examples above):
# VITE_IAP_BP_PRODUCT_IOS=kindrail_bp_premium_s0_ios
# VITE_IAP_BP_PRODUCT_ANDROID=kindrail_bp_premium_s0_android
# Native shell (Capacitor): product type — inapp (default) or subs (Play subs need android base plan id).
# VITE_IAP_BP_TYPE=inapp
# VITE_IAP_BP_ANDROID_PLAN_ID=

# -----------------------------------------------------------------------------
# Legal / store disclosure (GET /legal/public → companion LegalFooter; R7.M3/M4)
# -----------------------------------------------------------------------------
# Optional HTTPS URLs and contact. Omit or leave empty to hide that row in UI.
# KR_LEGAL_PRIVACY_URL=https://example.com/privacy
# KR_LEGAL_TERMS_URL=https://example.com/terms
# KR_LEGAL_SUPPORT_EMAIL=support@example.com
# KR_LEGAL_ACCOUNT_DELETION_URL=https://example.com/account-data
# Plain-text hint for store questionnaires / ratings (max ~2000 chars in protocol).
# KR_LEGAL_CONTENT_DESCRIPTORS=
