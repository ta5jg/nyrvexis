{
  "$ref": "#/definitions/NvDailyClaimResponse",
  "definitions": {
    "NvDailyClaimResponse": {
      "type": "object",
      "properties": {
        "v": {
          "type": "number",
          "const": 1
        },
        "ok": {
          "type": "boolean",
          "const": true
        },
        "dateUtc": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "claimed": {
          "type": "boolean"
        },
        "delta": {
          "type": "object",
          "properties": {
            "gold": {
              "type": "integer",
              "minimum": 0
            },
            "shards": {
              "type": "integer",
              "minimum": 0
            },
            "keys": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "gold",
            "shards",
            "keys"
          ],
          "additionalProperties": false
        },
        "inventory": {
          "type": "object",
          "properties": {
            "v": {
              "type": "number",
              "const": 1
            },
            "userId": {
              "type": "string",
              "minLength": 6,
              "maxLength": 80
            },
            "currency": {
              "type": "object",
              "properties": {
                "gold": {
                  "type": "integer",
                  "minimum": 0
                },
                "shards": {
                  "type": "integer",
                  "minimum": 0
                },
                "keys": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": [
                "gold",
                "shards",
                "keys"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "v",
            "userId",
            "currency"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "v",
        "ok",
        "dateUtc",
        "claimed",
        "inventory"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
