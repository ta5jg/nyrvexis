{
  "$ref": "#/definitions/KrBattlePassView",
  "definitions": {
    "KrBattlePassView": {
      "type": "object",
      "properties": {
        "seasonId": {
          "type": "string",
          "minLength": 1
        },
        "xp": {
          "type": "integer",
          "minimum": 0
        },
        "claimedFreeTiers": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "maxItems": 200
        },
        "hasPremium": {
          "type": "boolean"
        },
        "tiers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 999
              },
              "xpCumulative": {
                "type": "integer",
                "minimum": 0
              },
              "freeReward": {
                "type": "object",
                "properties": {
                  "gold": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "shards": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "keys": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "battlePassXp": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "catchUpTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  }
                },
                "additionalProperties": false
              },
              "premiumReward": {
                "type": "object",
                "properties": {
                  "gold": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "shards": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "keys": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "battlePassXp": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "catchUpTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "tier",
              "xpCumulative",
              "freeReward"
            ],
            "additionalProperties": false
          },
          "maxItems": 200
        }
      },
      "required": [
        "seasonId",
        "xp",
        "claimedFreeTiers",
        "hasPremium",
        "tiers"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
