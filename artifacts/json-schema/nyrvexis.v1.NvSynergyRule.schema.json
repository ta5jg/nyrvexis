{
  "$ref": "#/definitions/NvSynergyRule",
  "definitions": {
    "NvSynergyRule": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "requireRole": {
          "type": "string",
          "enum": [
            "tank",
            "dps",
            "support",
            "control"
          ]
        },
        "requireFaction": {
          "type": "string",
          "enum": [
            "vanguard",
            "marauder",
            "arcane",
            "ranger",
            "order"
          ]
        },
        "minCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "bonus": {
          "type": "object",
          "properties": {
            "hpFlat": {
              "type": "integer"
            },
            "atkFlat": {
              "type": "integer"
            },
            "defFlat": {
              "type": "integer"
            },
            "spdFlat": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "name",
        "minCount",
        "bonus"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
