                "minLength": 6,
                "maxLength": 80
              },
              "score": {
                "type": "integer"
              },
              "ticks": {
                "type": "integer",
                "minimum": 0
              },
              "remainingHp": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "userId",
              "score",
              "ticks",
              "remainingHp"
            ],
            "additionalProperties": false
          },
          "maxItems": 200
        }
      },
      "required": [
        "v",
        "ok",
        "dateUtc",
        "entries"
      ],
      "additionalProperties": false
    }
