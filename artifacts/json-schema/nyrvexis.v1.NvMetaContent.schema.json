{
  "$ref": "#/definitions/NvMetaContent",
  "definitions": {
    "NvMetaContent": {
      "type": "object",
      "properties": {
        "v": {
          "type": "number",
          "const": 1
        },
        "contentVersion": {
          "type": "string",
          "minLength": 1
        },
        "seasonId": {
          "type": "string",
          "minLength": 1
        },
        "economyDefaults": {
          "type": "object",
          "properties": {
            "dailyClaimGold": {
              "type": "integer",
              "minimum": 0,
              "default": 120
            },
            "dailyClaimShards": {
              "type": "integer",
              "minimum": 0,
              "default": 8
            },
            "dailyClaimKeys": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "shopGoldMulPct": {
              "type": "integer",
              "minimum": 10,
              "maximum": 500,
              "default": 100
            },
            "upgradeGoldMulPct": {
              "type": "integer",
              "minimum": 10,
              "maximum": 500,
              "default": 100
            },
            "upgradeShardMulPct": {
              "type": "integer",
              "minimum": 10,
              "maximum": 500,
              "default": 100
            },
            "battlePassXpPerDailyClaim": {
              "type": "integer",
              "minimum": 0,
              "default": 40
            },
            "battlePassXpPerLeaderboard": {
              "type": "integer",
              "minimum": 0,
              "default": 35
            },
            "battlePassXpDailyCap": {
              "type": "integer",
              "minimum": 0,
              "default": 500
            }
          },
          "additionalProperties": false
        },
        "quests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "scope": {
                "type": "string",
                "enum": [
                  "daily",
                  "weekly"
                ]
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "target": {
                "type": "integer",
                "minimum": 1,
                "maximum": 999
              },
              "track": {
                "type": "string",
                "enum": [
                  "daily_claim",
                  "leaderboard_submit",
                  "shop_buy"
                ]
              },
              "reward": {
                "type": "object",
                "properties": {
                  "gold": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "shards": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "keys": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "battlePassXp": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "catchUpTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "cosmeticId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "id",
              "scope",
              "title",
              "target",
              "track",
              "reward"
            ],
            "additionalProperties": false
          },
          "minItems": 1,
          "maxItems": 64
        },
        "battlePassTiers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 999
              },
              "xpCumulative": {
                "type": "integer",
                "minimum": 0
              },
              "freeReward": {
                "type": "object",
                "properties": {
                  "gold": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "shards": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "keys": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "battlePassXp": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "catchUpTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "cosmeticId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80
                  }
                },
                "additionalProperties": false
              },
              "premiumReward": {
                "type": "object",
                "properties": {
                  "gold": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "shards": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "keys": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "battlePassXp": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "catchUpTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "cosmeticId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "tier",
              "xpCumulative",
              "freeReward"
            ],
            "additionalProperties": false
          },
          "minItems": 1,
          "maxItems": 200
        },
        "cosmetics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              },
              "title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              "slot": {
                "type": "string",
                "enum": [
                  "frame",
                  "arena",
                  "title",
                  "hub"
                ]
              },
              "iconId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              }
            },
            "required": [
              "id",
              "title",
              "slot"
            ],
            "additionalProperties": false
          },
          "maxItems": 64,
          "default": []
        }
      },
      "required": [
        "v",
        "contentVersion",
        "seasonId",
        "economyDefaults",
        "quests",
        "battlePassTiers"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
