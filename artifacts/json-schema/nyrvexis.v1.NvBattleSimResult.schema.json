{
  "$ref": "#/definitions/NvBattleSimResult",
  "definitions": {
    "NvBattleSimResult": {
      "type": "object",
      "properties": {
        "v": {
          "type": "number",
          "const": 1
        },
        "seed": {
          "type": "object",
          "properties": {
            "seed": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "seed"
          ],
          "additionalProperties": false
        },
        "outcome": {
          "type": "string",
          "enum": [
            "a",
            "b",
            "draw"
          ]
        },
        "ticks": {
          "type": "integer",
          "minimum": 0
        },
        "remaining": {
          "type": "object",
          "properties": {
            "a": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            },
            "b": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "required": [
            "a",
            "b"
          ],
          "additionalProperties": false
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "t": {
                "type": "integer",
                "minimum": 0
              },
              "kind": {
                "type": "string",
                "enum": [
                  "hit",
                  "death",
                  "end",
                  "status_apply",
                  "status_tick",
                  "ability"
                ]
              },
              "src": {
                "type": "string",
                "minLength": 1
              },
              "dst": {
                "type": "string",
                "minLength": 1
              },
              "dmg": {
                "type": "integer",
                "minimum": 0
              },
              "crit": {
                "type": "boolean"
              },
              "status": {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "shield",
                      "bleed",
                      "taunt",
                      "stun"
                    ]
                  },
                  "dur": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 2000
                  },
                  "mag": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 1000000,
                    "default": 0
                  }
                },
                "required": [
                  "kind",
                  "dur"
                ],
                "additionalProperties": false
              },
              "abilityId": {
                "type": "string",
                "minLength": 1
              },
              "presentation": {
                "type": "object",
                "properties": {
                  "srcIntent": {
                    "type": "string",
                    "enum": [
                      "idle",
                      "advance",
                      "attack",
                      "hit",
                      "death"
                    ]
                  },
                  "dstIntent": {
                    "type": "string",
                    "enum": [
                      "idle",
                      "advance",
                      "attack",
                      "hit",
                      "death"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "t",
              "kind"
            ],
            "additionalProperties": false
          },
          "maxItems": 5000
