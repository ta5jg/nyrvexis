{
  "$ref": "#/definitions/NvDailyShopResponse",
  "definitions": {
    "NvDailyShopResponse": {
      "type": "object",
      "properties": {
        "v": {
          "type": "number",
          "const": 1
        },
        "ok": {
          "type": "boolean",
          "const": true
        },
        "dateUtc": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "contentVersion": {
          "type": "string",
          "minLength": 1
        },
        "offers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "offerId": {
                "type": "string",
                "minLength": 1
              },
              "archetype": {
                "type": "string",
                "minLength": 1
              },
              "priceGold": {
                "type": "integer",
                "minimum": 0
              },
              "qty": {
                "type": "integer",
                "minimum": 1,
                "default": 1
              }
            },
            "required": [
              "offerId",
              "archetype",
              "priceGold"
            ],
            "additionalProperties": false
          },
          "minItems": 1,
          "maxItems": 12
        }
      },
      "required": [
        "v",
        "ok",
        "dateUtc",
        "contentVersion",
        "offers"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
