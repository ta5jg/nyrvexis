{
  "name": "kindrail",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @kindrail/gateway dev",
    "dev:gateway": "pnpm --filter @kindrail/gateway dev",
    "dev:companion": "pnpm --filter @kindrail/companion-web dev",
    "dev:full": "concurrently -n gateway,web -c cyan,magenta \"pnpm run dev:gateway\" \"pnpm run dev:companion\"",
    "mobile:sync": "pnpm --filter @kindrail/companion-web build && pnpm --filter @kindrail/companion-mobile cap:sync",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

